PORT=3001
JWT_SECRET=ipuni-secret-key-change-in-production
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Nodemailer - Gmail SMTP (dùng App Password, không phải mật khẩu Gmail thường)
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password

# Google Gemini API Config (Khuyên dùng để đạt độ chính xác quét đơn thuốc cao nhất)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-flash-lite-latest
